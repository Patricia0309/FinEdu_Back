# <tu_proyecto_flutter>/ios/Flutter/engine_*.xcframework
# <tu_proyecto_flutter>/ios/Flutter/Flutter.podspec
# <tu_proyecto_flutter>/ios/Flutter/Generated.xcconfig
# <tu_proyecto_flutter>/.ios/